SECRET_KEY=your-secret-key-here-use-openssl-rand-hex-32
JWT_SECRET_KEY=your-jwt-secret-here-use-openssl-rand-hex-32
PORT=5000
FLASK_DEBUG=false

# Session cookies (set SESSION_COOKIE_SECURE=true behind HTTPS)
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME_HOURS=8

# PostgreSQL (recommended)
POSTGRES_USER=muhasaba
POSTGRES_PASSWORD=your-password-here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=muhasaba
DATABASE_URL=postgresql+psycopg2://muhasaba:your-password-here@localhost:5432/muhasaba

# SQLite (local dev without PostgreSQL)
# DATABASE_URL=sqlite:///muhasaba.db

# Connection pool (optional)
DB_POOL_RECYCLE=300

# MySQL (alternative)
# DATABASE_URL=mysql+pymysql://user:pass@localhost/muhasaba

# Email (required for OTP login and email verification)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
# Gmail app password without spaces (https://myaccount.google.com/apppasswords)
MAIL_PASSWORD=your16charapppassword
MAIL_DEFAULT_SENDER=your-email@gmail.com
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_EXPIRY_HOURS=48

# Rate limiting
RATELIMIT_ENABLED=true
RATELIMIT_LOGIN=10 per minute
RATELIMIT_OTP=10 per minute

# Platform branding (dynamic — admin can override per school/tenant in UI)
PLATFORM_NAME=منصة المحاسبة التعليمية
PLATFORM_TAGLINE=قياس الأداء، تطوير السلوك، وبناء مستقبل أفضل

# Platform owner tenant (Netrich administers; other orgs request licenses)
PLATFORM_OWNER_SLUG=netrich
PLATFORM_OWNER_NAME=Netrich
PLATFORM_OWNER_NAME_AR=نيتريش
