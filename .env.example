SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here
PORT=5000
FLASK_DEBUG=true

# PostgreSQL (recommended)
POSTGRES_USER=muhasaba
POSTGRES_PASSWORD=your-password-here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=muhasaba
DATABASE_URL=postgresql+psycopg2://muhasaba:your-password-here@localhost:5432/muhasaba

# SQLite (local dev without PostgreSQL)
# DATABASE_URL=sqlite:///muhasaba.db

# MySQL (alternative)
# DATABASE_URL=mysql+pymysql://user:pass@localhost/muhasaba
